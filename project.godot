; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited just fine using a text editor.

[application]

config/name="Animal Crossing"
config/description="Animal Crossing (GameCube) reimplemented in Godot Engine with C#."
config/version="1.0.0"
run/main_scene="res://godot/scenes/main.tscn"
config/features=PackedStringArray("4.6", "C#")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=640
window/size/viewport_height=480
window/size/resizable=true
window/size/window_width_override=1280
window/size/window_height_override=960
window/stretch/mode="disabled"
window/vsync/vsync_mode=1

[dotnet]

project/assembly_name="AnimalCrossing"

