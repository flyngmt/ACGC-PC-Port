# IDE folders
.idea/
.vs/
.vscode/*

# Caches
__pycache__
.mypy_cache
.cache/

# Original files
orig/*/*
!orig/*/.gitkeep
*.dol
*.rel
*.elf
*.o
*.map
*.MAP

# Build files (legacy C build)
build/
build32/
.ninja_*
build.ninja

# decompctx output
ctx.*
*.ctx

# Generated configs
objdiff.json
compile_commands.json

# Miscellaneous
/*.txt
!requirements.txt
*.exe

# For saving work files into (like IDB)
temp/

# Ignore the N64 SDK headers since we download them
# NOTE: include/PR/gbi.h and include/PR/ultratypes.h are force-tracked
# (git add -f) because they have TARGET_PC modifications for LE bitfields.
# configure.py skips download when they already exist.
include/PR/
include/gcc/
include/compiler/gcc/stdlib.h

# === Godot 4.x ===
# Godot import cache
.godot/

# Mono/C# build output
.mono/
bin/
obj/

# Export artifacts
export/
*.pck
*.zip

# NuGet
*.nupkg
packages/

# Disc images (user-provided, not checked in)
rom/
*.ciso
*.iso
*.gcm

# Save data
save/

# Texture packs
texture_pack/

# OS junk
.DS_Store
Thumbs.db
desktop.ini
